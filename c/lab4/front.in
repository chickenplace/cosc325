1 REM A program that does mathematical equations and fulfills requirements
2 REM B:20,C:43
10 LET A = 3
11 PR "Input B and C"
20 INPUT B, C
30 IF B > C THEN LET A = C/B
40 IF B < C THEN LET A = B*C
50 PR "Hello Dr. Toone"
60 GOTO 100
65 PR "Printing A, B, C, and D"
70 PR A, B, C, D
71 PR "Printing A*B*C*D"
75 PR A*B*C*D
80 END
100 LET D = 0
110 GOSUB 1000
120 GOTO 65
1000 LET D = D + A
1001 RETURN
RUN